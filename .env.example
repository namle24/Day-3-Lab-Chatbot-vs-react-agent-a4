# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google | local
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO

# BACKEND API
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/vinfast.db
RAG_INDEX_PATH=./data/rag_index.pkl
CORS_ORIGINS=*
